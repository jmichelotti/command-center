# Jellyfin server (Windows machine on LAN)
JELLYFIN_HOST=192.168.4.74
JELLYFIN_PORT=8096
JELLYFIN_API_KEY=your_jellyfin_api_key_here

# StoryGraph status file location (host path, mounted into container)
STORYGRAPH_STATUS_DIR=~/dev/storygraph-automation/status

# Status file directory (inside containers — usually leave as default)
# STATUS_DIR=/data/status

# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:8100,http://localhost:5180

# Staleness threshold in seconds (default 300 = 5 minutes)
# STALE_THRESHOLD_S=300
